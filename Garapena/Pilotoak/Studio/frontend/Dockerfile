FROM node:20-alpine AS build

WORKDIR /app

ARG VITE_BESU_RPC_URL
ARG VITE_CHAIN_ID
ARG VITE_NETWORK_NAME
ARG VITE_NATIVE_CURRENCY_NAME
ARG VITE_NATIVE_CURRENCY_SYMBOL
ARG VITE_BLOCK_EXPLORER_URL

ENV VITE_BESU_RPC_URL=$VITE_BESU_RPC_URL
ENV VITE_CHAIN_ID=$VITE_CHAIN_ID
ENV VITE_NETWORK_NAME=$VITE_NETWORK_NAME
ENV VITE_NATIVE_CURRENCY_NAME=$VITE_NATIVE_CURRENCY_NAME
ENV VITE_NATIVE_CURRENCY_SYMBOL=$VITE_NATIVE_CURRENCY_SYMBOL
ENV VITE_BLOCK_EXPLORER_URL=$VITE_BLOCK_EXPLORER_URL

COPY package*.json ./
RUN npm install

COPY index.html ./
COPY tsconfig.json ./
COPY tsconfig.node.json ./
COPY vite.config.ts ./
COPY public ./public
COPY src ./src

RUN npm run build

FROM nginx:1.27-alpine

COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 5007
