# Flask secret key for session cookies
FLASK_SECRET_KEY=change-me

# Besu RPC configuration (comma-separated list)
BESU_RPC_URL=http://192.168.100.1:8545,http://192.168.100.2:8545,http://192.168.100.3:8545,http://192.168.100.4:8545
BESU_CHAIN_ID=1337

# Bozketa contract deployment details
# Fill these after deploying with Garapena/Hardhat/scripts/deploy_Bozketa.js.
BOZKETA_PRIVATE_KEY=
BOZKETA_CONTRACT_ADDRESS=
BOZKETA_ABI_PATH=app/static/abi/bozketa.abi
